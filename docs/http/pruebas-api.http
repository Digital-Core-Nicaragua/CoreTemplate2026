# CoreTemplate — Pruebas de API
# Usar con la extensión REST Client de VS Code
# Instalar: https://marketplace.visualstudio.com/items?itemName=humao.rest-client
#
# INSTRUCCIONES:
# 1. Ejecutar la API: cd src/Host/CoreTemplate.Api && dotnet run
# 2. Abrir este archivo en VS Code
# 3. Hacer clic en "Send Request" sobre cada request
# 4. Primero ejecutar LOGIN y copiar el accessToken en @token

@baseUrl = https://localhost:5001
@token = PEGAR_ACCESS_TOKEN_AQUI
@refreshToken = PEGAR_REFRESH_TOKEN_AQUI

###############################################################################
# 1. AUTENTICACIÓN
###############################################################################

### 1.1 Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@coretemplate.com",
  "password": "Admin@1234!",
  "canal": 1
}

---

### 1.2 Solicitar reset de contraseña (dispara email automáticamente)
POST {{baseUrl}}/api/auth/solicitar-restablecimiento
Content-Type: application/json

{
  "email": "admin@coretemplate.com"
}

---

### 1.3 Logout
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "refreshToken": "{{refreshToken}}"
}

---

###############################################################################
# 2. CONFIGURACIÓN DEL SISTEMA
###############################################################################

### 2.1 Listar todos los parámetros agrupados
GET {{baseUrl}}/api/configuracion
Authorization: Bearer {{token}}

---

### 2.2 Listar parámetros del grupo Sistema
GET {{baseUrl}}/api/configuracion/grupo/Sistema
Authorization: Bearer {{token}}

---

### 2.3 Obtener un parámetro por clave
GET {{baseUrl}}/api/configuracion/sistema.nombre
Authorization: Bearer {{token}}

---

### 2.4 Actualizar el nombre del sistema
PUT {{baseUrl}}/api/configuracion/sistema.nombre
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "valor": "Mi ERP S.A."
}

---

### 2.5 Actualizar moneda
PUT {{baseUrl}}/api/configuracion/sistema.moneda
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "valor": "NIO"
}

---

### 2.6 Actualizar serie de facturación
PUT {{baseUrl}}/api/configuracion/facturacion.serie
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "valor": "A001"
}

---

###############################################################################
# 3. NOTIFICACIONES
###############################################################################

### 3.1 Listar mis notificaciones
GET {{baseUrl}}/api/notificaciones?pagina=1&tamano=20
Authorization: Bearer {{token}}

---

### 3.2 Listar solo no leídas
GET {{baseUrl}}/api/notificaciones?soloNoLeidas=true
Authorization: Bearer {{token}}

---

### 3.3 Conteo de no leídas (para el badge 🔔)
GET {{baseUrl}}/api/notificaciones/no-leidas/count
Authorization: Bearer {{token}}

---

### 3.4 Marcar una notificación como leída (reemplazar {id})
PUT {{baseUrl}}/api/notificaciones/00000000-0000-0000-0000-000000000000/leer
Authorization: Bearer {{token}}

---

### 3.5 Marcar todas como leídas
PUT {{baseUrl}}/api/notificaciones/leer-todas
Authorization: Bearer {{token}}

---

###############################################################################
# 4. EMAIL TEMPLATES
###############################################################################

### 4.1 Listar todas las plantillas
GET {{baseUrl}}/api/email-templates
Authorization: Bearer {{token}}

---

### 4.2 Listar plantillas del módulo Auth
GET {{baseUrl}}/api/email-templates?modulo=Auth
Authorization: Bearer {{token}}

---

### 4.3 Obtener plantilla por ID (reemplazar {id})
GET {{baseUrl}}/api/email-templates/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{token}}

---

### 4.4 Vista previa de plantilla (reemplazar {id})
POST {{baseUrl}}/api/email-templates/00000000-0000-0000-0000-000000000000/preview
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "variables": {
    "NombreUsuario": "Juan Pérez",
    "LinkReset": "https://misistema.com/reset?token=ABC123",
    "ExpiraEn": "1 hora"
  }
}

---

### 4.5 Enviar correo de prueba (reemplazar {id})
POST {{baseUrl}}/api/email-templates/00000000-0000-0000-0000-000000000000/enviar-prueba
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "destinatario": "cortezyuriel@gmail.com",
  "variables": {
    "NombreUsuario": "Juan Pérez",
    "LinkReset": "https://misistema.com/reset?token=ABC123",
    "ExpiraEn": "1 hora"
  }
}

---

### 4.6 Actualizar plantilla (reemplazar {id})
PUT {{baseUrl}}/api/email-templates/00000000-0000-0000-0000-000000000000
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "asunto": "Restablece tu contraseña en {{SistemaNombre}}",
  "cuerpoHtml": "<p>Hola {{NombreUsuario}},</p><p><a href='{{LinkReset}}'>Restablecer contraseña</a></p>",
  "variables": ["NombreUsuario", "LinkReset", "ExpiraEn"]
}

---

###############################################################################
# 5. ARCHIVOS
###############################################################################

### 5.1 Listar archivos (filtrar por módulo)
GET {{baseUrl}}/api/archivos?moduloOrigen=RRHH
Authorization: Bearer {{token}}

---

### 5.2 Obtener metadatos de un archivo (reemplazar {id})
GET {{baseUrl}}/api/archivos/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{token}}

---

### 5.3 Obtener URL de acceso de un archivo (reemplazar {id})
GET {{baseUrl}}/api/archivos/00000000-0000-0000-0000-000000000000/url
Authorization: Bearer {{token}}

---

### 5.4 Eliminar archivo (reemplazar {id})
DELETE {{baseUrl}}/api/archivos/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{token}}

---
# NOTA: Para subir archivos usar Swagger UI (multipart/form-data)
# POST /api/archivos con campos: archivo, contexto, moduloOrigen, entidadId

###############################################################################
# 6. PDF TEMPLATES
###############################################################################

### 6.1 Listar diseños disponibles
GET {{baseUrl}}/api/pdf-templates/disenios
Authorization: Bearer {{token}}

---

### 6.2 Listar todas las plantillas PDF
GET {{baseUrl}}/api/pdf-templates
Authorization: Bearer {{token}}

---

### 6.3 Listar plantillas del módulo Nomina
GET {{baseUrl}}/api/pdf-templates?modulo=Nomina
Authorization: Bearer {{token}}

---

### 6.4 Vista previa de plantilla PDF (reemplazar {id})
POST {{baseUrl}}/api/pdf-templates/00000000-0000-0000-0000-000000000000/preview
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "datos": {
    "Empleado": "Juan Pérez",
    "Cargo": "Desarrollador Senior",
    "Período": "Enero 2025",
    "Salario Bruto": "$3,000.00",
    "Deducciones": "$450.00",
    "Salario Neto": "$2,550.00"
  }
}

---

### 6.5 Actualizar configuración corporativa de plantilla PDF (reemplazar {id})
PUT {{baseUrl}}/api/pdf-templates/00000000-0000-0000-0000-000000000000
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Comprobante de Pago",
  "codigoTemplate": "vertical-estandar",
  "nombreEmpresa": "Mi Empresa S.A.",
  "logoUrl": "",
  "colorEncabezado": "#1a2e5a",
  "colorTextoHeader": "#ffffff",
  "colorAcento": "#4f46e5",
  "textoSecundario": "RUC: 001-000000-0000",
  "textoPiePagina": "{{NombreEmpresa}} — Generado el {{FechaGeneracion}}",
  "mostrarNumeroPagina": true,
  "mostrarFechaGeneracion": true,
  "marcaDeAgua": ""
}

---

###############################################################################
# 7. AUDITORÍA
###############################################################################

### 7.1 Listar logs de auditoría (últimos 20)
GET {{baseUrl}}/api/auditoria?pagina=1&tamano=20
Authorization: Bearer {{token}}

---

### 7.2 Filtrar por entidad
GET {{baseUrl}}/api/auditoria?entidad=Usuario&pagina=1&tamano=20
Authorization: Bearer {{token}}

---

### 7.3 Filtrar por acción
GET {{baseUrl}}/api/auditoria?accion=Deleted&pagina=1&tamano=20
Authorization: Bearer {{token}}

---

### 7.4 Filtrar por rango de fechas
GET {{baseUrl}}/api/auditoria?fechaDesde=2025-01-01&fechaHasta=2025-01-31
Authorization: Bearer {{token}}

---

### 7.5 Ver detalle de un log (reemplazar {id})
GET {{baseUrl}}/api/auditoria/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{token}}

---

### 7.6 Historial de una entidad específica (reemplazar {entidadId})
GET {{baseUrl}}/api/auditoria/entidad/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{token}}

---

### 7.7 Actividad de un usuario (reemplazar {usuarioId})
GET {{baseUrl}}/api/auditoria/usuario/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{token}}

---

###############################################################################
# 8. AUTH — FLUJO COMPLETO
###############################################################################

### 8.1 Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@coretemplate.com",
  "password": "Admin@1234!",
  "canal": 1
}

---

### 8.2 Ver perfil
GET {{baseUrl}}/api/perfil
Authorization: Bearer {{token}}

---

### 8.3 Listar roles
GET {{baseUrl}}/api/roles
Authorization: Bearer {{token}}

---

### 8.4 Listar usuarios
GET {{baseUrl}}/api/usuarios?pagina=1&tamanoPagina=10
Authorization: Bearer {{token}}

---

### 8.5 Crear usuario
POST {{baseUrl}}/api/auth/registro
Content-Type: application/json

{
  "email": "nuevo@test.com",
  "nombre": "Usuario Prueba",
  "password": "Test@1234!",
  "confirmPassword": "Test@1234!",
  "tipoUsuario": 1
}

---

###############################################################################
# FLUJO DE PRUEBA SUGERIDO — MÓDULOS NUEVOS
###############################################################################
#
# 1. POST /api/auth/login                          → Obtener token
# 2. GET  /api/configuracion                       → Ver parámetros del sistema
# 3. PUT  /api/configuracion/sistema.nombre        → Cambiar nombre de la empresa
# 4. GET  /api/email-templates                     → Ver plantillas de correo
# 5. POST /api/email-templates/{id}/enviar-prueba  → Enviar correo de prueba
# 6. GET  /api/pdf-templates/disenios              → Ver diseños disponibles
# 7. POST /api/pdf-templates/{id}/preview          → Ver preview de PDF
# 8. GET  /api/notificaciones/no-leidas/count      → Ver badge de notificaciones
# 9. GET  /api/auditoria                           → Ver logs de auditoría
# 10. POST /api/auth/solicitar-restablecimiento    → Disparar email automático
#
###############################################################################
